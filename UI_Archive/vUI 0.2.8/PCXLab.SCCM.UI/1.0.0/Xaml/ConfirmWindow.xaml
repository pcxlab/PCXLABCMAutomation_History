<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Confirm Execution"
    Height="580"
    Width="600"
    WindowStartupLocation="CenterScreen"
    Background="#F3F2F1"
    FontFamily="Segoe UI"
    ResizeMode="NoResize"
    WindowStyle="None"
    AllowsTransparency="True">

    <Border BorderBrush="#0078D4" BorderThickness="1" CornerRadius="4" Background="#F3F2F1">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Header -->
                <RowDefinition Height="*" />    <!-- Content -->
                <RowDefinition Height="Auto" /> <!-- Actions -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="15" Background="#0078D4" CornerRadius="3,3,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="CONFIRM" FontWeight="Bold" Foreground="White" FontSize="18" VerticalAlignment="Center" />
                    <TextBlock Text=" | Review Deployment Details" Foreground="White" FontSize="16" VerticalAlignment="Center" Margin="5,0,0,0" />
                </StackPanel>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" Margin="20" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Please verify the following information is correct:" Margin="0,0,0,15" FontWeight="SemiBold" Foreground="#333333" />

                    <Border Background="White" CornerRadius="4" Padding="15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Source Path -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Source Path:" FontWeight="Bold" Margin="0,5" />
                            <TextBlock x:Name="txtConfSource" Grid.Row="0" Grid.Column="1" TextWrapping="Wrap" Margin="0,5" Foreground="#666666" />

                            <!-- Type -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Type:" FontWeight="Bold" Margin="0,5" />
                            <TextBlock x:Name="txtConfType" Grid.Row="1" Grid.Column="1" Margin="0,5" Foreground="#666666" />

                            <!-- Name -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Name:" FontWeight="Bold" Margin="0,5" />
                            <TextBlock x:Name="txtConfName" Grid.Row="2" Grid.Column="1" FontWeight="SemiBold" Margin="0,5" />

                            <!-- Metadata -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Company:" FontWeight="Bold" Margin="0,5" />
                            <TextBlock x:Name="txtConfCompany" Grid.Row="3" Grid.Column="1" Margin="0,5" Foreground="#666666" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Product:" FontWeight="Bold" Margin="0,5" />
                            <TextBlock x:Name="txtConfProduct" Grid.Row="4" Grid.Column="1" Margin="0,5" Foreground="#666666" />

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Version:" FontWeight="Bold" Margin="0,5" />
                            <TextBlock x:Name="txtConfVersion" Grid.Row="5" Grid.Column="1" Margin="0,5" Foreground="#666666" />

                           <!-- Targets -->
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="DP Groups:" FontWeight="Bold" Margin="0,5" />
                            <TextBlock x:Name="txtConfGroups" Grid.Row="6" Grid.Column="1" TextWrapping="Wrap" Margin="0,5" Foreground="#666666" />

                            <TextBlock Grid.Row="7" Grid.Column="0" Text="DPs:" FontWeight="Bold" Margin="0,5" />
                            <TextBlock x:Name="txtConfDPs" Grid.Row="7" Grid.Column="1" TextWrapping="Wrap" Margin="0,5" Foreground="#666666" />

                            <TextBlock Grid.Row="8" Grid.Column="0" Text="CMGs:" FontWeight="Bold" Margin="0,5" />
                            <TextBlock x:Name="txtConfCMGs" Grid.Row="8" Grid.Column="1" TextWrapping="Wrap" Margin="0,5" Foreground="#666666" />

                            <TextBlock Grid.Row="9" Grid.Column="0" Text="Ref Number:" FontWeight="Bold" Margin="0,5" />
                            <TextBlock x:Name="txtConfRef" Grid.Row="9" Grid.Column="1" Margin="0,5" Foreground="#666666" />

                            <TextBlock Grid.Row="10" Grid.Column="0" Text="Reviewer:" FontWeight="Bold" Margin="0,5" />
                            <TextBlock x:Name="txtConfReviewer" Grid.Row="10" Grid.Column="1" Margin="0,5" Foreground="#666666" />

                            <TextBlock Grid.Row="11" Grid.Column="0" Text="Comments:" FontWeight="Bold" Margin="0,5" />
                            <TextBlock x:Name="txtConfComments" Grid.Row="11" Grid.Column="1" TextWrapping="Wrap" Margin="0,5" Foreground="#666666" />
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Actions -->
            <Border Grid.Row="2" Background="#FFFFFF" Padding="20" CornerRadius="0,0,3,3" BorderBrush="#EEEEEE" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="btnConfBack" Grid.Column="0" Content="BACK" Height="40" Margin="0,0,10,0" Background="#F3F2F1" BorderBrush="#CCCCCC" FontWeight="SemiBold" Cursor="Hand" />
                    <Button x:Name="btnConfProceed" Grid.Column="1" Content="PROCEED" Height="40" Margin="10,0,0,0" Background="#107C10" Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
