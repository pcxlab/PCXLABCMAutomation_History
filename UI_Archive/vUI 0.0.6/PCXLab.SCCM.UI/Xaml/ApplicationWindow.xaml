<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="PCXLab SCCM Application Tool"
    Height="600"
    Width="450"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize">

    <Grid Margin="10">

        <Label
            Content="Source Path:"
            VerticalAlignment="Top" />

        <TextBox
            x:Name="txtSourcePath"
            Margin="0,25,80,0"
            Height="25"
            VerticalAlignment="Top" />

        <Button
            x:Name="btnBrowse"
            Content="..."
            Width="60"
            Height="25"
            Margin="0,25,0,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top" />

        <Label
            Content="Application Name:"
            Margin="0,60,0,0"
            VerticalAlignment="Top" />

        <TextBox
            x:Name="txtApplicationName"
            Margin="0,85,0,0"
            Height="25"
            VerticalAlignment="Top"
            IsReadOnly="True" />

        <Label
            Content="Company:"
            Margin="0,120,0,0"
            VerticalAlignment="Top" />

        <TextBox
            x:Name="txtCompany"
            Margin="0,145,0,0"
            Height="25"
            VerticalAlignment="Top"
            IsReadOnly="True" />

        <Label
            Content="Product:"
            Margin="0,180,0,0"
            VerticalAlignment="Top" />

        <TextBox
            x:Name="txtProduct"
            Margin="0,205,0,0"
            Height="25"
            VerticalAlignment="Top"
            IsReadOnly="True" />

        <Label
            Content="Version:"
            Margin="0,240,0,0"
            VerticalAlignment="Top" />

        <TextBox
            x:Name="txtVersion"
            Margin="0,265,0,0"
            Height="25"
            VerticalAlignment="Top"
            IsReadOnly="True" />

        <Label
            Content="Distribution Point Group:"
            Margin="0,300,0,0"
            VerticalAlignment="Top" />

        <ComboBox
            x:Name="cmbDPGroup"
            Margin="0,325,0,0"
            Height="25"
            VerticalAlignment="Top" />

        <Button
            x:Name="btnCreateApplication"
            Content="Create Application"
            Height="30"
            Margin="0,365,0,0"
            VerticalAlignment="Top" />

        <Label
            Content="Status / Log:"
            Margin="0,410,0,0"
            VerticalAlignment="Top" />

        <TextBox
            x:Name="txtStatus"
            Margin="0,435,0,0"
            Height="60"
            VerticalAlignment="Top"
            IsReadOnly="True"
            AcceptsReturn="True"
            TextWrapping="Wrap"
            VerticalScrollBarVisibility="Auto" />

    </Grid>

</Window>