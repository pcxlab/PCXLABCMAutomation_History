<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="PCXLab SCCM Automation Tool"
    Height="800"
    Width="900"
    WindowStartupLocation="CenterScreen"
    Background="#F3F2F1"
    FontFamily="Segoe UI">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Header -->
            <RowDefinition Height="Auto" /> <!-- Source Path Card -->
            <RowDefinition Height="*" />    <!-- Main Content (2 Columns) -->
            <RowDefinition Height="Auto" /> <!-- Request Info Card -->
            <RowDefinition Height="Auto" /> <!-- Actions -->
            <RowDefinition Height="150" />  <!-- Log -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Margin="0,0,0,15" Padding="10" Background="#0078D4" CornerRadius="4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="PCXLAB" FontWeight="Bold" Foreground="White" FontSize="20" VerticalAlignment="Center" />
                <TextBlock Text=" | SCCM Automation Tool" Foreground="White" FontSize="18" VerticalAlignment="Center" Margin="5,0,0,0" />
            </StackPanel>
        </Border>

        <!-- Source Path Card -->
        <Border Grid.Row="1" Background="White" CornerRadius="4" Padding="15" Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Color="#CCCCCC" ShadowDepth="2" Opacity="0.5" />
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="1. Select Source Folder" FontWeight="Bold" FontSize="14" Foreground="#0078D4" Margin="0,0,0,10" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtSourcePath" Grid.Column="0" Height="30" VerticalContentAlignment="Center" BorderBrush="#CCCCCC" Padding="5" />
                    <Button x:Name="btnBrowse" Grid.Column="1" Content="Browse Folder" Width="120" Margin="10,0,0,0" Background="#0078D4" Foreground="White" BorderThickness="0" Height="30" FontWeight="SemiBold">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="2" />
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- Metadata Card -->
            <Border Grid.Column="0" Background="White" CornerRadius="4" Padding="15" Margin="0,0,10,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Color="#CCCCCC" ShadowDepth="2" Opacity="0.5" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="2. Extracted Metadata" FontWeight="Bold" FontSize="14" Foreground="#0078D4" Margin="0,0,0,15" />
                    
                    <StackPanel x:Name="pnlAppName">
                        <Label Content="Application Name:" Foreground="#666666" Padding="0" />
                        <TextBox x:Name="txtAppName" Margin="0,5,0,10" Height="25" IsReadOnly="True" Background="#F9F9F9" BorderBrush="#EEEEEE" Padding="3" VerticalContentAlignment="Center" />
                    </StackPanel>

                    <StackPanel x:Name="pnlPkgName" Visibility="Collapsed">
                        <Label Content="Package Name:" Foreground="#666666" Padding="0" />
                        <TextBox x:Name="txtPkgName" Margin="0,5,0,10" Height="25" IsReadOnly="True" Background="#F9F9F9" BorderBrush="#EEEEEE" Padding="3" VerticalContentAlignment="Center" />
                    </StackPanel>

                    <Label Content="Company:" Foreground="#666666" Padding="0" />
                    <TextBox x:Name="txtCompany" Margin="0,5,0,10" Height="25" IsReadOnly="True" Background="#F9F9F9" BorderBrush="#EEEEEE" Padding="3" VerticalContentAlignment="Center" />

                    <Label Content="Product:" Foreground="#666666" Padding="0" />
                    <TextBox x:Name="txtProduct" Margin="0,5,0,10" Height="25" IsReadOnly="True" Background="#F9F9F9" BorderBrush="#EEEEEE" Padding="3" VerticalContentAlignment="Center" />

                    <Label Content="Version:" Foreground="#666666" Padding="0" />
                    <TextBox x:Name="txtVersion" Margin="0,5,0,0" Height="25" IsReadOnly="True" Background="#F9F9F9" BorderBrush="#EEEEEE" Padding="3" VerticalContentAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Distribution Card -->
            <Border Grid.Column="1" Background="White" CornerRadius="4" Padding="15" Margin="10,0,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Color="#CCCCCC" ShadowDepth="2" Opacity="0.5" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="3. Distribution Configuration" FontWeight="Bold" FontSize="14" Foreground="#0078D4" Margin="0,0,0,5" />
                        <TextBlock Text="Select targets for content distribution" FontSize="11" Foreground="#999999" Margin="0,0,0,10" />
                    </StackPanel>

                    <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0,1,0,0" BorderBrush="#EEEEEE">
                        <TabItem Header="DP Groups">
                            <ScrollViewer Margin="0,10,0,0" VerticalScrollBarVisibility="Auto" BorderThickness="1" BorderBrush="#EEEEEE">
                                <StackPanel x:Name="pnlDPGroups" Margin="5" />
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="Specific DPs">
                            <ScrollViewer Margin="0,10,0,0" VerticalScrollBarVisibility="Auto" BorderThickness="1" BorderBrush="#EEEEEE">
                                <StackPanel x:Name="pnlDPs" Margin="5" />
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>

                    <Button x:Name="btnRefreshDPs" Grid.Row="2" Content="Refresh Lists" Margin="0,10,0,0" Height="25" Background="#F3F2F1" BorderBrush="#CCCCCC" />
                </Grid>
            </Border>
        </Grid>

        <!-- Request Information Card -->
        <Border Grid.Row="3" Background="White" CornerRadius="4" Padding="15" Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Color="#CCCCCC" ShadowDepth="2" Opacity="0.5" />
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="4. Request Information" FontWeight="Bold" FontSize="14" Foreground="#0078D4" Margin="0,0,0,10" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <Label Content="Reference Number:" Foreground="#666666" Padding="0" />
                        <TextBox x:Name="txtRefNumber" Margin="0,5,0,10" Height="25" BorderBrush="#CCCCCC" Padding="3" VerticalContentAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <Label Content="Reviewer Name:" Foreground="#666666" Padding="0" />
                        <TextBox x:Name="txtReviewer" Margin="0,5,0,10" Height="25" BorderBrush="#CCCCCC" Padding="3" VerticalContentAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2">
                        <Label Content="Comments:" Foreground="#666666" Padding="0" />
                        <TextBox x:Name="txtComments" Margin="0,5,0,0" Height="60" BorderBrush="#CCCCCC" Padding="3" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Actions -->
        <Border Grid.Row="4" Background="White" CornerRadius="4" Padding="15" Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Color="#CCCCCC" ShadowDepth="2" Opacity="0.5" />
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <RadioButton x:Name="radApp" Content="Application" IsChecked="True" Margin="0,0,20,0" FontWeight="SemiBold" FontSize="14" />
                    <RadioButton x:Name="radPkg" Content="Package" FontWeight="SemiBold" FontSize="14" />
                </StackPanel>
                <Button x:Name="btnCreate" Grid.Column="1" Content="CREATE APPLICATION" Height="45" Margin="20,0,0,0" Background="#107C10" Foreground="White" FontWeight="Bold" FontSize="14" BorderThickness="0" Cursor="Hand" />
            </Grid>
        </Border>

        <!-- Log Area -->
        <Border Grid.Row="5" Background="#1E1E1E" CornerRadius="4" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="CONSOLE LOG" Foreground="#AAAAAA" FontSize="10" FontWeight="Bold" Margin="0,0,0,5" />
                <TextBox x:Name="txtStatus" Grid.Row="1" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="Transparent" Foreground="#D4D4D4" FontFamily="Consolas" BorderThickness="0" />
            </Grid>
        </Border>
    </Grid>
</Window>