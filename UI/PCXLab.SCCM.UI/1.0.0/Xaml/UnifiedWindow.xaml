<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="PCXLab SCCM Automation Tool"
    Height="700"
    Width="920"
    MinHeight="580"
    MinWidth="850"
    WindowStartupLocation="CenterScreen"
    Background="#F3F2F1"
    FontFamily="Segoe UI">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Header -->
            <RowDefinition Height="*" MinHeight="250" />    <!-- Main Content -->
            <RowDefinition Height="Auto" /> <!-- Splitter Row -->
            <RowDefinition Height="110" MinHeight="70" MaxHeight="300" />  <!-- Log Row -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Margin="0,0,0,10" Padding="10" Background="#0078D4" CornerRadius="4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="PCXLAB" FontWeight="Bold" Foreground="White" FontSize="20" VerticalAlignment="Center" />
                <TextBlock Text=" | SCCM Automation Tool" Foreground="White" FontSize="18" VerticalAlignment="Center" Margin="5,0,0,0" />
            </StackPanel>
        </Border>

        <!-- Main Content (2 Columns) -->
        <Grid Grid.Row="1" Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" MinWidth="380" />
                <ColumnDefinition Width="1*" MinWidth="380" />
            </Grid.ColumnDefinitions>

            <!-- Column 0: Inputs & Actions -->
            <Grid Grid.Column="0" Margin="0,0,6,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />    <!-- Scrollable content -->
                    <RowDefinition Height="Auto" /> <!-- Docked Actions -->
                </Grid.RowDefinitions>

                <!-- ScrollViewer for Left Side Inputs -->
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,6,0">
                    <StackPanel>
                        <!-- 1. Select Source Folder -->
                        <Border Background="White" CornerRadius="4" Padding="12" Margin="0,0,0,10">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" Color="#CCCCCC" ShadowDepth="1" Opacity="0.4" />
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="1. Select Source Folder" FontWeight="Bold" FontSize="14" Foreground="#0078D4" Margin="0,0,0,8" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="txtSourcePath" Grid.Column="0" Height="28" VerticalContentAlignment="Center" BorderBrush="#CCCCCC" Padding="5" />
                                    <Button x:Name="btnBrowse" Grid.Column="1" Content="Browse Folder" Width="110" Margin="8,0,0,0" Background="#0078D4" Foreground="White" BorderThickness="0" Height="28" FontWeight="SemiBold">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="2" />
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- 2. Extracted Metadata -->
                        <Border Background="White" CornerRadius="4" Padding="12" Margin="0,0,0,10">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" Color="#CCCCCC" ShadowDepth="1" Opacity="0.4" />
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" /> <!-- Title -->
                                    <RowDefinition Height="Auto" /> <!-- Name -->
                                    <RowDefinition Height="Auto" /> <!-- Company & Product -->
                                    <RowDefinition Height="Auto" /> <!-- Version -->
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="2. Extracted Metadata" FontWeight="Bold" FontSize="14" Foreground="#0078D4" Margin="0,0,0,8" />

                                <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel x:Name="pnlAppName" Grid.Row="0">
                                            <Label Content="Application Name:" Foreground="#666666" Padding="0" />
                                            <TextBox x:Name="txtAppName" Margin="0,3,0,0" Height="25" IsReadOnly="True" Background="#F9F9F9" BorderBrush="#EEEEEE" Padding="3" VerticalContentAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel x:Name="pnlPkgName" Grid.Row="1" Visibility="Collapsed">
                                            <Label Content="Package Name:" Foreground="#666666" Padding="0" />
                                            <TextBox x:Name="txtPkgName" Margin="0,3,0,0" Height="25" IsReadOnly="True" Background="#F9F9F9" BorderBrush="#EEEEEE" Padding="3" VerticalContentAlignment="Center" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,5,6">
                                    <Label Content="Company:" Foreground="#666666" Padding="0" />
                                    <TextBox x:Name="txtCompany" Margin="0,3,0,0" Height="25" IsReadOnly="True" Background="#F9F9F9" BorderBrush="#EEEEEE" Padding="3" VerticalContentAlignment="Center" />
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="1" Margin="5,0,0,6">
                                    <Label Content="Product:" Foreground="#666666" Padding="0" />
                                    <TextBox x:Name="txtProduct" Margin="0,3,0,0" Height="25" IsReadOnly="True" Background="#F9F9F9" BorderBrush="#EEEEEE" Padding="3" VerticalContentAlignment="Center" />
                                </StackPanel>

                                <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,5,0">
                                    <Label Content="Version:" Foreground="#666666" Padding="0" />
                                    <TextBox x:Name="txtVersion" Margin="0,3,0,0" Height="25" IsReadOnly="True" Background="#F9F9F9" BorderBrush="#EEEEEE" Padding="3" VerticalContentAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 4. Request Information -->
                        <Border Background="White" CornerRadius="4" Padding="12">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" Color="#CCCCCC" ShadowDepth="1" Opacity="0.4" />
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="4. Request Information" FontWeight="Bold" FontSize="14" Foreground="#0078D4" Margin="0,0,0,8" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,5,6">
                                        <Label Content="Reference Number:" Foreground="#666666" Padding="0" />
                                        <TextBox x:Name="txtRefNumber" Margin="0,3,0,0" Height="25" BorderBrush="#CCCCCC" Padding="3" VerticalContentAlignment="Center" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="5,0,0,6">
                                        <Label Content="Reviewer Name:" Foreground="#666666" Padding="0" />
                                        <TextBox x:Name="txtReviewer" Margin="0,3,0,0" Height="25" BorderBrush="#CCCCCC" Padding="3" VerticalContentAlignment="Center" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2">
                                        <Label Content="Comments:" Foreground="#666666" Padding="0" />
                                        <TextBox x:Name="txtComments" Margin="0,3,0,0" Height="50" BorderBrush="#CCCCCC" Padding="3" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- 5. Actions Card (Always docked at the bottom of the left column) -->
                <Border Grid.Row="1" Background="White" CornerRadius="4" Padding="12" Margin="0,10,0,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" Color="#CCCCCC" ShadowDepth="1" Opacity="0.4" />
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <RadioButton x:Name="radApp" Content="Application" IsChecked="True" Margin="0,0,15,0" FontWeight="SemiBold" FontSize="13" />
                            <RadioButton x:Name="radPkg" Content="Package" FontWeight="SemiBold" FontSize="13" />
                        </StackPanel>
                        <Button x:Name="btnCreate" Grid.Column="1" Content="CREATE APPLICATION" Height="40" Margin="15,0,0,0" Background="#107C10" Foreground="White" FontWeight="Bold" FontSize="13" BorderThickness="0" Cursor="Hand" />
                    </Grid>
                </Border>
            </Grid>

            <!-- Column 1: Distribution Config Card -->
            <Border Grid.Column="1" Background="White" CornerRadius="4" Padding="12" Margin="6,0,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" Color="#CCCCCC" ShadowDepth="1" Opacity="0.4" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="3. Distribution Configuration" FontWeight="Bold" FontSize="14" Foreground="#0078D4" Margin="0,0,0,2" />
                        <TextBlock Text="Select targets for content distribution" FontSize="11" Foreground="#999999" Margin="0,0,0,8" />
                    </StackPanel>

                    <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0,1,0,0" BorderBrush="#EEEEEE">
                        <TabItem Header="DP Groups">
                            <ScrollViewer Margin="0,8,0,0" VerticalScrollBarVisibility="Auto" BorderThickness="1" BorderBrush="#EEEEEE">
                                <StackPanel x:Name="pnlDPGroups" Margin="5" />
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Distribution Points">
                            <ScrollViewer Margin="0,8,0,0" VerticalScrollBarVisibility="Auto" BorderThickness="1" BorderBrush="#EEEEEE">
                                <StackPanel x:Name="pnlDPs" Margin="5" />
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="CMGs">
                            <ScrollViewer Margin="0,8,0,0" VerticalScrollBarVisibility="Auto" BorderThickness="1" BorderBrush="#EEEEEE">
                                <StackPanel x:Name="pnlCMGs" Margin="5" />
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>

                    <Button x:Name="btnRefreshDPs" Grid.Row="2" Content="Refresh Lists" Margin="0,8,0,0" Height="25" Background="#F3F2F1" BorderBrush="#CCCCCC" />
                </Grid>
            </Border>
        </Grid>

        <!-- GridSplitter between Main Content (Row 1) and Console Log (Row 3) -->
        <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Center" Background="#CCCCCC" ResizeBehavior="PreviousAndNext" Margin="0,5" />

        <!-- Log Area -->
        <Border Grid.Row="3" Background="#1E1E1E" CornerRadius="4" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="CONSOLE LOG" Foreground="#AAAAAA" FontSize="10" FontWeight="Bold" Margin="0,0,0,4" />
                <TextBox x:Name="txtStatus" Grid.Row="1" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="Transparent" Foreground="#D4D4D4" FontFamily="Consolas" BorderThickness="0" />
            </Grid>
        </Border>
    </Grid>
</Window>